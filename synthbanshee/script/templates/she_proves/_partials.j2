{# she_proves/_partials.j2 — shared macros imported by all she_proves templates.
   Import with: {% from "_partials.j2" import common_rules, output_format, speakers_block %}
#}

{% macro speakers_block(speakers) %}
SPEAKERS
========
{% for sp in speakers %}
- ID: {{ sp.speaker_id }}  Role: {{ sp.role }}  Gender: {{ sp.gender }}
{% endfor %}
{% endmacro %}

{% macro common_rules(target_duration_minutes, extra_rules=[]) %}
DIALOGUE RULES
==============
1. Every utterance MUST be Hebrew text only — no transliteration, no English.
2. Follow the intensity_arc chronologically across the turns.
3. Each turn is 1–4 sentences. Aim for roughly {{ (target_duration_minutes * 60 / 15) | int }} turns total.
4. pause_before_s must be in [0.0, 1.5] s; use longer gaps at scene transitions.
5. emotional_state must be one of: neutral, angry, fearful, sad, pleading, threatening, calm.
6. Do NOT use binary Violence/Non-Violence labels anywhere in text or metadata.
{% for rule in extra_rules %}
{{ loop.index + 6 }}. {{ rule }}
{% endfor %}
{% endmacro %}

{% macro output_format() %}
OUTPUT FORMAT
=============
Return ONLY valid JSON — no prose, no markdown fences.

For turns with intensity 3–5, annotate 1–2 emotionally loaded phrases using
"phrase_hints". Each hint must reference character offsets within that turn's
"text" field (0-indexed, exclusive end).  Valid hint values:
  "stress"       — faster, louder, higher pitch
  "slow"         — deliberate slow-down for menacing weight
  "break_before" — dramatic pause before the phrase
  "break_after"  — let the phrase land with silence after
  "menace"       — cold coercion: slower with a leading pause

For intensity 1–2 turns set "phrase_hints" to [].

{
  "turns": [
    {
      "speaker_id": "<speaker_id from SPEAKERS section>",
      "text": "<Hebrew utterance>",
      "intensity": <integer 1–5>,
      "pause_before_s": <float 0.0–1.5>,
      "emotional_state": "<state>",
      "phrase_hints": [
        {
          "phrase_id": "t<turn_index>_p<hint_index>",
          "hint": "<hint value>",
          "char_start_original": <integer>,
          "char_end_original": <integer>
        }
      ]
    }
  ]
}
{% endmacro %}
